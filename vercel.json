{
  "buildCommand": "flutter build web --release",
  "outputDirectory": "build/web",
  "installCommand": "flutter pub get",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" },
    { "source": "/api/paynow", "destination": "https://www.paynow.co.zw/interface/remotetransaction" },
    { "source": "/api/paynow-poll/:path*", "destination": "https://www.paynow.co.zw/interface/:path*" }
  ]
}